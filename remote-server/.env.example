# Copy this file to .env and fill in your values

# Render PostgreSQL connection string (from Render dashboard → your DB → Connection String)
DATABASE_URL=postgresql://user:password@host/dbname

# JWT secret — long random string, must match JWT_SECRET in the main app's .env
JWT_SECRET=change-this-to-a-long-random-string

# Port (Render sets this automatically, don't change)
PORT=3001
